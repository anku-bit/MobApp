<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MobApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>
    <style name="DashBtn">
        <item name="android:layout_width">170dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/btn_pill</item>
        <item name="android:textColor">@color/purple_text</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="CalcBtn">
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/btn_pill</item>
        <item name="android:textColor">@color/purple_text</item>
        <item name="android:textSize">17sp</item>
    </style>
</resources>
