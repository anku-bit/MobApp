<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:orientation="vertical" android:padding="20dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="⏱️ Stopwatch" android:textColor="@color/white"
        android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="32dp"/>
    <TextView android:id="@+id/tvTime" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="00:00:00.00"
        android:textColor="@color/accent" android:textSize="44sp" android:textStyle="bold"
        android:gravity="center" android:fontFamily="monospace"
        android:layout_marginBottom="32dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="12dp">
        <Button android:id="@+id/btnStart" android:layout_width="0dp" android:layout_height="54dp"
            android:layout_weight="1" android:layout_marginEnd="8dp"
            android:text="▶ START" android:textColor="@color/white"
            android:backgroundTint="@color/green" android:textAllCaps="false"
            android:background="@drawable/btn_pill"/>
        <Button android:id="@+id/btnStop" android:layout_width="0dp" android:layout_height="54dp"
            android:layout_weight="1" android:layout_marginStart="8dp"
            android:text="⏸ STOP" android:textColor="@color/white"
            android:backgroundTint="#E74C3C" android:textAllCaps="false"
            android:background="@drawable/btn_pill"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="20dp">
        <Button android:id="@+id/btnLap" android:layout_width="0dp" android:layout_height="50dp"
            android:layout_weight="1" android:layout_marginEnd="8dp"
            android:text="🏁 LAP" android:textColor="@color/purple_text"
            android:background="@drawable/btn_pill" android:textAllCaps="false"/>
        <Button android:id="@+id/btnReset" android:layout_width="0dp" android:layout_height="50dp"
            android:layout_weight="1" android:layout_marginStart="8dp"
            android:text="⟳ RESET" android:textColor="@color/purple_text"
            android:background="@drawable/btn_pill" android:textAllCaps="false"/>
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🏁 Lap Times" android:textColor="@color/white"
        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <ListView android:id="@+id/lvLaps" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:dividerHeight="1dp"/>
    <Button android:id="@+id/btnBack" android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginTop="10dp" android:text="BACK"
        android:textColor="@color/purple_text" android:background="@drawable/btn_pill"
        android:textAllCaps="false"/>
</LinearLayout>
