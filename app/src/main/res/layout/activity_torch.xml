<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:gravity="center" android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🔦 Torch" android:textColor="@color/white"
        android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="30dp"/>
    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Torch is OFF" android:textColor="@color/grey_hint"
        android:textSize="18sp" android:layout_marginBottom="30dp"/>
    <Button android:id="@+id/btnToggle" android:layout_width="180dp" android:layout_height="56dp"
        android:text="TOGGLE TORCH" android:textColor="@color/purple_text"
        android:background="@drawable/btn_pill" android:layout_marginBottom="40dp"/>
    <Button android:id="@+id/btnBack" android:layout_width="150dp" android:layout_height="48dp"
        android:text="BACK" android:textColor="@color/purple_text" android:background="@drawable/btn_pill"/>
</LinearLayout>
