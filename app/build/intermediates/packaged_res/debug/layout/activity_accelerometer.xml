<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:gravity="center" android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="📐 Accelerometer" android:textColor="@color/white"
        android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="40dp"/>
    <TextView android:id="@+id/tvX" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="X: 0.00" android:textColor="@color/accent" android:textSize="22sp" android:layout_marginBottom="14dp"/>
    <TextView android:id="@+id/tvY" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Y: 0.00" android:textColor="@color/accent" android:textSize="22sp" android:layout_marginBottom="14dp"/>
    <TextView android:id="@+id/tvZ" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Z: 0.00" android:textColor="@color/accent" android:textSize="22sp" android:layout_marginBottom="40dp"/>
    <Button android:id="@+id/btnBack" android:layout_width="150dp" android:layout_height="48dp"
        android:text="BACK" android:textColor="@color/purple_text" android:background="@drawable/btn_pill"/>
</LinearLayout>
