<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:gravity="center" android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎵 Music Player" android:textColor="@color/white"
        android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="30dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎶" android:textSize="60sp" android:layout_marginBottom="20dp"/>
    <TextView android:id="@+id/tvSong" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="No song loaded" android:textColor="@color/grey_hint"
        android:textSize="15sp" android:gravity="center" android:layout_marginBottom="30dp"/>
    <Button android:id="@+id/btnPlayPause" android:layout_width="200dp" android:layout_height="54dp"
        android:text="▶ PLAY" android:textColor="@color/purple_text"
        android:background="@drawable/btn_pill" android:layout_marginBottom="14dp"/>
    <Button android:id="@+id/btnStop" android:layout_width="200dp" android:layout_height="50dp"
        android:text="⏹ STOP" android:textColor="@color/purple_text"
        android:background="@drawable/btn_pill" android:layout_marginBottom="40dp"/>
    <Button android:id="@+id/btnBack" android:layout_width="150dp" android:layout_height="48dp"
        android:text="BACK" android:textColor="@color/purple_text" android:background="@drawable/btn_pill"/>
</LinearLayout>
