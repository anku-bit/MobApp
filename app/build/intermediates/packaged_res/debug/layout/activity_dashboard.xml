<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="14dp">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#1F1B2E"
        android:padding="16dp" android:layout_marginBottom="16dp">
        <TextView android:id="@+id/tvWelcome" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Welcome!"
            android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvMode" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Mode: Online"
            android:textColor="@color/grey_hint" android:textSize="12sp" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- EMERGENCY (Full width red) -->
    <Button android:id="@+id/btnEmergencySOS"
        android:layout_width="match_parent" android:layout_height="64dp"
        android:layout_marginBottom="16dp" android:background="@drawable/btn_pill_red"
        android:text="🚨  EMERGENCY SOS  🚨" android:textColor="@color/white"
        android:textSize="16sp" android:textStyle="bold" android:textAllCaps="false"/>

    <!-- Category: Tools & Calculators -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🧮 Tools &amp; Calculators" android:textColor="@color/accent"
        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="2" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnCalc"          style="@style/DashBtn" android:text="🔢 Calculator"/>
        <Button android:id="@+id/btnSciCalc"        style="@style/DashBtn" android:text="🔬 Sci Calc"/>
        <Button android:id="@+id/btnBMI"            style="@style/DashBtn" android:text="⚖️ BMI Calc"/>
        <Button android:id="@+id/btnUnitConverter"  style="@style/DashBtn" android:text="📐 Unit Conv"/>
        <Button android:id="@+id/btnAgeCalc"        style="@style/DashBtn" android:text="🎂 Age Calc"/>
        <Button android:id="@+id/btnStopwatch"      style="@style/DashBtn" android:text="⏱️ Stopwatch"/>
    </GridLayout>

    <!-- Category: Hardware & Sensors -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="📡 Hardware &amp; Sensors" android:textColor="@color/accent"
        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="2" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnTorch"    style="@style/DashBtn" android:text="🔦 Torch"/>
        <Button android:id="@+id/btnCompass"  style="@style/DashBtn" android:text="🧭 Compass"/>
        <Button android:id="@+id/btnAccel"    style="@style/DashBtn" android:text="📐 Accelerometer"/>
        <Button android:id="@+id/btnSensor"   style="@style/DashBtn" android:text="🌡️ Sensors"/>
        <Button android:id="@+id/btnBattery"  style="@style/DashBtn" android:text="🔋 Battery"/>
        <Button android:id="@+id/btnSystemInfo" style="@style/DashBtn" android:text="ℹ️ System Info"/>
    </GridLayout>

    <!-- Category: Connectivity -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="📶 Connectivity" android:textColor="@color/accent"
        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="2" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnBluetooth" style="@style/DashBtn" android:text="📡 Bluetooth"/>
        <Button android:id="@+id/btnWifi"      style="@style/DashBtn" android:text="📶 WiFi Info"/>
    </GridLayout>

    <!-- Category: Media & Camera -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="📷 Media &amp; Camera" android:textColor="@color/accent"
        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="2" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnCamera"     style="@style/DashBtn" android:text="📷 Camera"/>
        <Button android:id="@+id/btnQRScanner"  style="@style/DashBtn" android:text="📱 QR Scanner"/>
        <Button android:id="@+id/btnMedia"      style="@style/DashBtn" android:text="🎵 Music Player"/>
        <Button android:id="@+id/btnVideo"      style="@style/DashBtn" android:text="🎬 Video Player"/>
    </GridLayout>

    <!-- Category: Notes & Info -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="📝 Notes &amp; Info" android:textColor="@color/accent"
        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="2" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnNotes"   style="@style/DashBtn" android:text="📝 My Notes"/>
        <Button android:id="@+id/btnQuiz"    style="@style/DashBtn" android:text="❓ Online Quiz"/>
    </GridLayout>

    <!-- Profile & Logout -->
    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="2" android:layout_marginBottom="24dp">
        <Button android:id="@+id/btnProfile" style="@style/DashBtn" android:text="👤 Profile"/>
        <Button android:id="@+id/btnLogout"
            android:layout_width="0dp" android:layout_columnWeight="1"
            android:layout_height="70dp" android:layout_margin="5dp"
            android:background="@drawable/bg_card" android:text="🚪 Logout"
            android:textColor="@color/white" android:textSize="13sp" android:textAllCaps="false"/>
    </GridLayout>

</LinearLayout>
</ScrollView>
