<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:gravity="center" android:orientation="vertical" android:padding="24dp">
    <TextView android:id="@+id/tvTitle" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Choose Mode" android:textColor="@color/white"
        android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="50dp"/>
    <Button android:id="@+id/btnOffline" android:layout_width="260dp" android:layout_height="56dp"
        android:text="CLICK FOR OFFLINE" android:textColor="@color/purple_text"
        android:background="@drawable/btn_pill" android:layout_marginBottom="24dp"/>
    <Button android:id="@+id/btnOnline" android:layout_width="260dp" android:layout_height="56dp"
        android:text="CLICK FOR ONLINE" android:textColor="@color/purple_text"
        android:background="@drawable/btn_pill" android:layout_marginBottom="80dp"/>
    <Button android:id="@+id/btnBack" android:layout_width="160dp" android:layout_height="48dp"
        android:text="BACK" android:textColor="@color/purple_text" android:background="@drawable/btn_pill"/>
</LinearLayout>
