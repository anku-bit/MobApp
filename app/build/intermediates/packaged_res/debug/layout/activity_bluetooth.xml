<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:orientation="vertical" android:padding="20dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="📡 Bluetooth" android:textColor="@color/white"
        android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>
    <TextView android:id="@+id/tvBtStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Checking..." android:textColor="@color/grey_hint" android:textSize="15sp" android:layout_marginBottom="20dp"/>
    <Button android:id="@+id/btnEnable" android:layout_width="220dp" android:layout_height="54dp"
        android:text="SCAN PAIRED DEVICES" android:textColor="@color/purple_text"
        android:background="@drawable/btn_pill" android:layout_marginBottom="16dp"/>
    <ListView android:id="@+id/lvDevices" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:dividerHeight="1dp"/>
    <Button android:id="@+id/btnBack" android:layout_width="150dp" android:layout_height="48dp"
        android:layout_gravity="center" android:layout_marginTop="10dp"
        android:text="BACK" android:textColor="@color/purple_text" android:background="@drawable/btn_pill"/>
</LinearLayout>
